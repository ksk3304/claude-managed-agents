{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "claude-managed-agents-control-plane",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-18",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  // v4 (Issue #186): MAKOTOくん R-Mail bridge は AgentMail webhook +
  // queue consumer + cron の 3 経路のみを提供する。self-hosted sandbox
  // 系の bindings (assets/ASSETS, containers/Sandbox, DO Sandbox &
  // IsolateRunner, worker_loaders PROXY_LOADER/LOADER, browser/BROWSER,
  // ai/AI, r2/BACKUP_BUCKET, send_email/SEND_EMAIL, KV SECRETS &
  // EGRESS_POLICIES) は v4 廃棄で全削除した。残る bindings は MAKOTO
  // bridge 用 (MAKOTO_KV / DB / MAKOTO_THREAD_LOCK / MAKOTO_OAUTH_LEASE /
  // queues) のみ。
  //
  // 設計ノート: worktrees/issue-186/diary/2026/05/24/issue-186-
  // cloudflare-phase2-rmail-bridge-ts/plan-draft-v4-cloud-env-only.md
  "kv_namespaces": [
    // MAKOTO bridge KV (Issue #186): sender→user_slug→agent_id mapping,
    // envelope-encrypted OAuth vault entries (`vault:oauth:<user>:*`),
    // and per-confirm-token TTL nonces. `scripts/ensure-kv.mjs` patches
    // the real id at prebuild.
    {
      "binding": "MAKOTO_KV",
      "id": "1d58a2a715044909972de6cc2a0e9f40",
    },
  ],
  // D1: AgentMail bridge dedupe / threads / sent_messages / audit logs.
  // `database_id` is patched on `prebuild` by `scripts/ensure-d1.mjs`.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "claude-managed-agents-db",
      "database_id": "bfcfeac4-38a2-476d-82c8-e3e89f0116dd",
      "migrations_dir": "./migrations",
    },
  ],
  "durable_objects": {
    "bindings": [
      // MAKOTO bridge: per-RFC-822-message exclusion DO. One instance
      // per thread key (`idFromName(eventKeyForRfc822(...))`) — guards
      // against two consumers racing to call `sessions.create` +
      // AgentMail send for the same inbound message.
      {
        "class_name": "ThreadLock",
        "name": "MAKOTO_THREAD_LOCK",
      },
      // MAKOTO bridge: per-user OAuth refresh lease + access_token
      // cache DO. One instance per user (`idFromName(userSlug)`) so
      // refresh attempts for the same user funnel through a single
      // single-threaded actor (no in-flight refresh race, no duplicate
      // audit rows, no thundering herd on Google's token endpoint).
      {
        "class_name": "OAuthLease",
        "name": "MAKOTO_OAUTH_LEASE",
      },
    ],
  },
  "migrations": [
    {
      "new_sqlite_classes": ["Sandbox", "IsolateRunner"],
      "tag": "v1",
    },
    {
      "new_sqlite_classes": ["ThreadLock"],
      "tag": "v2",
    },
    // v3 廃棄: v4 cloud-env-only に移行したため self-hosted sandbox DO を
    // 全削除。Cloudflare に deploy された時、`deleted_classes` で指定した
    // DO クラスの全 instance が platform 側で reaped される。
    {
      "deleted_classes": ["Sandbox", "IsolateRunner"],
      "tag": "v3",
    },
    // v4: per-user OAuth refresh lease + token cache DO (Phase 2
    // OAuth lease, plan v4 §5.4.3). State is in-memory only — the
    // class registration here is what Cloudflare needs to route
    // `MAKOTO_OAUTH_LEASE.get(id)` calls; no D1 row schema for the DO
    // itself.
    {
      "new_sqlite_classes": ["OAuthLease"],
      "tag": "v4",
    },
  ],
  // Cron schedules (see `src/index.ts` `scheduled` for dispatch logic):
  //   - `0 4 * * *`  (4 AM UTC) — daily prune of AgentMail bridge
  //     `dedupe` + `agentmail_webhook_seen` rows past their 30-day TTL.
  //   - `0 14 * * *` (14:00 UTC = 23:00 JST) — daily-report runner
  //     (`src/scheduled/daily-report.ts`). Aggregates the previous JST
  //     day's session logs from Memory Stores, summarises them with
  //     `client.messages.create`, and writes `/<date>.md` to the
  //     per-user / shared `daily_report_*_store`. TS port of the
  //     Cloud Run `scripts/cma_daily_report.py` (Issue #186 Phase 2).
  "triggers": {
    "crons": ["0 4 * * *", "0 14 * * *"],
  },
  // Cloudflare Queues for the AgentMail bridge (Issue #186). One
  // single-purpose queue carries verified webhook deliveries from the
  // HTTP handler to the long-running consumer. The same Worker is
  // both producer (handler) and consumer (`queue()` export); Cloudflare
  // bills the consumer at the worker-invocation rate so there's no
  // need for a second deploy. `max_batch_size` / `max_retries` are
  // conservative defaults — tune in `wrangler dev` based on observed
  // bursts.
  "queues": {
    "producers": [
      {
        "binding": "MAKOTO_QUEUE",
        "queue": "makoto-agentmail-events",
      },
    ],
    "consumers": [
      {
        "queue": "makoto-agentmail-events",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 5,
      },
    ],
  },
}
