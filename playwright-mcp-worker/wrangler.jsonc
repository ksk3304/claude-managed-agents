{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "makoto-playwright-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-04",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "browser": {
    "binding": "BROWSER",
  },
  "kv_namespaces": [
    {
      "binding": "MAKOTO_KV",
      "id": "1d58a2a715044909972de6cc2a0e9f40",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "PlaywrightMCP",
        "name": "PLAYWRIGHT_MCP",
      },
    ],
  },
  "migrations": [
    {
      "new_sqlite_classes": ["PlaywrightMCP"],
      "tag": "v1",
    },
  ],
}
